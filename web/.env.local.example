# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # anon/public key

# ── TMDB ──────────────────────────────────────────────────────────────────────
# Found at: themoviedb.org → Settings → API
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_READ_ACCESS_TOKEN=eyJhbGciOiJIUzI1NiJ9...  # "API Read Access Token" (v4 bearer token)

# ── ML API ────────────────────────────────────────────────────────────────────
# Local dev: http://localhost:8000
# Production: your Render service URL
ML_API_URL=http://localhost:8000

# ── AI Providers ─────────────────────────────────────────────────────────────
# Set ONE of these for local development. On production, users provide their
# own key via Profile → AI Settings (BYOK).
# ANTHROPIC_API_KEY=sk-ant-...    # console.anthropic.com → API Keys
OPENAI_API_KEY=sk-...              # platform.openai.com → API Keys

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback