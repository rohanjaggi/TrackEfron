# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: supabase.com → Project Settings → API
# Note: config.py reads NEXT_PUBLIC_SUPABASE_URL (same value as the web URL)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service_role key (NOT anon key — has full DB access)

# ── TMDB ──────────────────────────────────────────────────────────────────────
# Found at: themoviedb.org → Settings → API
TMDB_API_KEY=your_tmdb_api_key_here
